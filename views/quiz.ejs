<!DOCTYPE html>
<html>
<head>
  <title>Quiz</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container" id="container">
  <div class="top">
    <span id="qCount">Q 1/10</span>
    <div class="progress"><div class="bar" id="bar"></div></div>
    <span id="timer">10s</span>
    <button class="music-btn" id="musicBtn" onclick="toggleMusic()">🎵</button>
  </div>

  <h2 id="categoryTitle">Quiz</h2>

  <div class="question-box">
    <h3 id="question">Loading...</h3>
  </div>

  <div class="options" id="options"></div>

  <button class="next" id="nextBtn">Next</button>
  
  <div class="footer">
    <h3>Quiz Arena</h3>
    <p>Test your knowledge across various categories</p>
  </div>
</div>

<script src="auth.js"></script>
<script src="questions.js"></script>
<script src="script.js"></script>
<script>
// Simple music toggle for now
function toggleMusic() {
  alert('Music feature coming soon!');
}
const Score = require("./models/Score");

app.post("/save-score", async (req,res)=>{
  await Score.create(req.body);
  res.json({success:true});
});
</script>
</body>
</html>
